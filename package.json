{
  "name": "reinhardt-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npx vite --config client/vite.config.js",
    "dev:server": "nodemon server/server.js --watch server",
    "build": "npm run build:client",
    "build:client": "npx vite build --config client/vite.config.js",
    "preview": "npx vite preview --config client/vite.config.js",
    "start": "node server/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3",
    "vite": "^8.0.11"
  }
}
